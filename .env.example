NODE_ENV=development
PORT=3000
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long-here
JWT_EXPIRES_IN=7d
DATABASE_URL="postgresql://postgres:admin123@localhost:5432/medicine_db"

# Medicine Module Configuration
# Number of days before expiry to mark medicine as "EXPIRING_SOON"
MEDICINE_EXPIRING_SOON_DAYS=30

# Cron expression for daily expiry sync job (default: daily at midnight)
MEDICINE_EXPIRY_CRON="0 0 * * *"

# Timezone for the cron job (default: UTC)
MEDICINE_EXPIRY_CRON_TIMEZONE="UTC"