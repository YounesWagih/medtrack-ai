NODE_ENV=development
PORT=3000
FRONTEND_URL="http://localhost:5173"
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long-here
JWT_EXPIRES_IN=7d
CHAT_RATE_LIMIT=50
DATABASE_URL="postgresql://username:password@host:port/db_name"

# Number of days before expiry to mark medicine as "EXPIRING_SOON"
MEDICINE_EXPIRING_SOON_DAYS=30

# Cron expression for daily expiry sync job (default: daily at midnight)
MEDICINE_EXPIRY_CRON="0 0 * * *"

# Timezone for the cron job (default: UTC)
MEDICINE_EXPIRY_CRON_TIMEZONE="UTC"

# Redis configuration
REDIS_URL=redis://localhost:6379

# Medicine details cache TTL in seconds (default: 24 hours)
MEDICINE_DETAILS_CACHE_TTL=86400

LOG_LEVEL=debug
LOG_FORMAT=pretty
LOG_REDACTION_MODE=strict
SERVICE_NAME=medtrack-backend
SERVICE_VERSION=1.0.0
METRICS_ENABLED=true
METRICS_PORT=9464
TRACING_ENABLED=true
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
OTEL_TRACES_SAMPLER_RATIO=1

OPENROUTER_API_KEY=<your api>
MODEL_NAME="name"
